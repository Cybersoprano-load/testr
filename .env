# Общие настройки стенда. docker compose подхватывает этот файл автоматически.

# --- Kafka ---
KAFKA_TOPIC=messages
# Несколько партиций нужны, чтобы многопоточная вычитка в заглушке реально параллелилась.
KAFKA_PARTITIONS=6
# Число consumer-потоков заглушки (п.1.3 #3).
KAFKA_CONCURRENCY=3

# --- PostgreSQL ---
POSTGRES_DB=kafka_stub
POSTGRES_USER=kafka_stub
POSTGRES_PASSWORD=kafka_stub

# --- Заглушка ---
# Начальная задержка записи в БД (мс), п.3. Меняется на лету через PUT /api/delay.
STUB_DELAY_MS=1000
